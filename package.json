    "@sendgrid/mail": "^8.1.6",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "aws-sdk": "^2.1693.0",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~55.0.0",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "google-libphonenumber": "^3.2.44",
    "helmet": "^8.1.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "nodemon": "^3.1.14",
    "patch-package": "^8.0.0",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "react-test-renderer": "19.1.0",
    "stripe": "^20.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
